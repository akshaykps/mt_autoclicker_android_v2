<?xml version="1.0" encoding="utf-8"?>
<!-- Compact ready state for full-page screenshot FGS -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_notif_ss_circle"
        android:contentDescription="@null"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_screenshot" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_ss_ready_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:text="Screenshot ready"
            android:textColor="#FF1C1C1E"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/notif_ss_ready_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Open any scrollable screen → tap Snapshot"
            android:textColor="#FF6B6B70"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/notif_ss_ready_close"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_notif_circle_dark"
        android:contentDescription="Close"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_close" />
</LinearLayout>
