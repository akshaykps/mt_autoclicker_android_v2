<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <TextView
        android:id="@+id/notif_play_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="Playing"
        android:textColor="#FF1C1C1E"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/notif_play_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:fontFamily="monospace"
        android:maxLines="1"
        android:text="0/0"
        android:textColor="#FF1C1C1E"
        android:textSize="13sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/notif_play_pause"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_notif_circle_dark"
        android:contentDescription="Pause"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_pause" />

    <ImageView
        android:id="@+id/notif_play_stop"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_notif_stop_circle"
        android:contentDescription="Stop"
        android:padding="9dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_stop" />
</LinearLayout>
