<?xml version="1.0" encoding="utf-8"?>
<!-- Single-row compact content: visible collapsed on OxygenOS -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <ImageView
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_rec_dot" />

    <TextView
        android:id="@+id/notif_rec_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="Recording"
        android:textColor="#FF1C1C1E"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/notif_rec_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="monospace"
        android:maxLines="1"
        android:text="00:00"
        android:textColor="#FF1C1C1E"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notif_rec_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="· 0"
        android:textColor="#FF6B6B70"
        android:textSize="13sp" />

    <ImageView
        android:id="@+id/notif_rec_stop"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="@drawable/bg_notif_stop_circle"
        android:contentDescription="Stop"
        android:padding="9dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_stop" />
</LinearLayout>
