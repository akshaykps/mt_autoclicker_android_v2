<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="mt_deep">#FF060B27</color>
    <color name="mt_card">#FF0D1333</color>
    <color name="mt_border">#FF1E2D5A</color>
    <color name="mt_blue">#FF3B82F6</color>
    <color name="mt_purple">#FF8B5CF6</color>
    <!-- Cold-start default follows dark branding; night qualifier overrides when system is dark. -->
    <color name="mt_splash_bg">#FF05050C</color>

    <!-- Cold-start theme: shown until Compose splash takes over. -->
    <style name="Theme.MtAutoClicker.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/mt_splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">400</item>
        <item name="postSplashScreenTheme">@style/Theme.MtAutoClicker</item>
        <item name="android:statusBarColor">@color/mt_splash_bg</item>
        <item name="android:navigationBarColor">@color/mt_splash_bg</item>
        <item name="android:windowBackground">@drawable/splash_screen_background</item>
    </style>

    <style name="Theme.MtAutoClicker" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/mt_deep</item>
        <item name="android:navigationBarColor">@color/mt_deep</item>
        <item name="android:windowBackground">@color/mt_deep</item>
    </style>
</resources>
